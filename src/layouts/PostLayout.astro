---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: MarkdownHeading[];
  /** 较新的一篇（右侧链接） */
  newer?: CollectionEntry<'blog'>;
  /** 较早的一篇（左侧链接） */
  older?: CollectionEntry<'blog'>;
}
const { post, headings, newer, older } = Astro.props;
const dateStr = post.data.date.toISOString().slice(0, 10);
---
<BaseLayout title={post.data.title} description={post.data.summary} article={true}>
  <main id="main" class="mx-auto max-w-2xl px-4 py-12">
    <a
      href="/blog"
      class="font-mono text-[13px] text-zinc-400 transition-colors hover:text-accent dark:hover:text-accent-soft"
    >
      ← 返回 Blog
    </a>

    <header class="mt-6 mb-8">
      <h1 class="text-3xl font-bold tracking-tight">{post.data.title}</h1>
      <div class="mt-3 flex flex-wrap items-center gap-2 font-mono text-xs text-zinc-400">
        <time datetime={dateStr}>{dateStr}</time>
        {post.data.tags.map((t) => (
          <a
            href={`/blog/tags/${t}`}
            class="rounded bg-zinc-100 px-2 py-0.5 transition-colors hover:text-accent dark:bg-zinc-800 dark:hover:text-accent-soft"
          >
            #{t}
          </a>
        ))}
      </div>
    </header>

    <TOC headings={headings} />

    <article
      class="prose prose-zinc max-w-none dark:prose-invert prose-headings:scroll-mt-20 prose-pre:border prose-pre:border-zinc-200 dark:prose-pre:border-zinc-800"
    >
      <slot />
    </article>

    {(older || newer) && (
      <nav class="mt-12 flex justify-between gap-6 border-t border-zinc-200 pt-6 font-mono text-[13px] dark:border-zinc-800">
        {older ? (
          <a
            href={`/blog/${older.id}`}
            class="text-zinc-500 transition-colors hover:text-accent dark:text-zinc-400 dark:hover:text-accent-soft"
          >
            ← {older.data.title}
          </a>
        ) : (
          <span />
        )}
        {newer ? (
          <a
            href={`/blog/${newer.id}`}
            class="text-right text-zinc-500 transition-colors hover:text-accent dark:text-zinc-400 dark:hover:text-accent-soft"
          >
            {newer.data.title} →
          </a>
        ) : (
          <span />
        )}
      </nav>
    )}
  </main>
</BaseLayout>
