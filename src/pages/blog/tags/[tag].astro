---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---
<BaseLayout title={`#${tag}`} description={`标签「${tag}」下的文章`}>
  <main id="main" class="mx-auto max-w-2xl px-4 py-14">
    <a
      href="/blog/tags"
      class="font-mono text-[13px] text-zinc-400 transition-colors hover:text-accent dark:hover:text-accent-soft"
    >
      ← 全部标签
    </a>
    <h1 class="mt-4 text-2xl font-bold tracking-tight">#{tag}</h1>
    <p class="mt-2 font-mono text-sm text-zinc-500 dark:text-zinc-400">{posts.length} 篇文章</p>
    <div class="mt-8 divide-y divide-zinc-100 dark:divide-zinc-800/70">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </main>
</BaseLayout>
