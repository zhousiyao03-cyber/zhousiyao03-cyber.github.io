---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const counts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags) counts.set(t, (counts.get(t) ?? 0) + 1);
}
const tags = [...counts.entries()].sort((a, b) => b[1] - a[1]);
---
<BaseLayout title="Tags" description="按标签浏览文章">
  <main id="main" class="mx-auto max-w-2xl px-4 py-14">
    <h1 class="text-2xl font-bold tracking-tight">Tags</h1>
    <p class="mt-2 font-mono text-sm text-zinc-500 dark:text-zinc-400">{tags.length} 个标签</p>
    <div class="mt-6 flex flex-wrap gap-2">
      {tags.map(([tag, count]) => (
        <a
          href={`/blog/tags/${tag}`}
          class="rounded-full border border-zinc-200 px-3 py-1 font-mono text-sm text-zinc-600 transition-colors hover:border-accent hover:text-accent dark:border-zinc-800 dark:text-zinc-300 dark:hover:border-accent-soft dark:hover:text-accent-soft"
        >
          #{tag} <span class="text-zinc-400">{count}</span>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>
