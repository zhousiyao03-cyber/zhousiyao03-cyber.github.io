---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404">
  <main class="mx-auto flex max-w-2xl flex-col items-center px-4 py-28 text-center">
    <p class="font-mono text-6xl font-bold text-accent dark:text-accent-soft">404</p>
    <p class="mt-4 text-zinc-500 dark:text-zinc-400">这个页面不存在。</p>
    <a
      href="/"
      class="mt-6 font-mono text-sm text-accent transition-colors hover:underline dark:text-accent-soft"
    >
      ← 回首页
    </a>
  </main>
</BaseLayout>
