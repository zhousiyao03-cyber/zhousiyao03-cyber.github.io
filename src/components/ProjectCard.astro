---
import type { CollectionEntry } from 'astro:content';
interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { name, role, stack, links } = project.data;
---
<article
  class="rounded-xl border border-zinc-200 p-5 transition-colors hover:border-zinc-300 dark:border-zinc-800 dark:hover:border-zinc-700"
>
  <h3 class="font-semibold">{name}</h3>
  <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">{role}</p>
  {stack.length > 0 && (
    <ul class="mt-3 flex flex-wrap gap-1.5">
      {stack.map((t) => (
        <li class="rounded bg-zinc-100 px-2 py-0.5 font-mono text-[11px] text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300">
          {t}
        </li>
      ))}
    </ul>
  )}
  {links.length > 0 && (
    <div class="mt-4 flex gap-4 font-mono text-[13px]">
      {links.map((l) => (
        <a href={l.url} class="text-accent hover:underline dark:text-accent-soft">{l.label} ↗</a>
      ))}
    </div>
  )}
</article>
