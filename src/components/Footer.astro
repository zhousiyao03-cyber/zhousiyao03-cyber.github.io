---
import { SITE, SOCIAL } from '../config';
const year = new Date().getFullYear();
---
<footer class="mt-20 border-t border-zinc-200 dark:border-zinc-800">
  <div
    class="mx-auto flex max-w-2xl flex-col gap-3 px-4 py-8 font-mono text-[13px] text-zinc-500 dark:text-zinc-400 sm:flex-row sm:items-center sm:justify-between"
  >
    <span>© {year} {SITE.author}</span>
    <nav class="flex gap-4">
      {SOCIAL.map((s) => (
        <a
          href={s.href}
          class="transition-colors hover:text-zinc-900 dark:hover:text-zinc-100"
        >
          {s.label}
        </a>
      ))}
    </nav>
  </div>
</footer>
